# ── SDP ECloud environment variables ─────────────────────────────────────────
#
# Copy to .env and fill in real values for local dev.
# In production, EigenCompute KMS injects these at container startup.

# BIP-39 mnemonic — wallet index 0 is the TEE relayer address.
# Dev default: Hardhat/Anvil test mnemonic (never use in production).
MNEMONIC="test test test test test test test test test test test junk"

# Deployed SdpSettlement contract address on Sepolia.
# Leave empty to run in simulation-only mode (relay is skipped).
SETTLEMENT_CONTRACT=0xB1F0214E2277c2843A9D2d90cCEAd664d19C9f71

# Alchemy Sepolia RPC endpoint (also used by the pre-screener for fork simulation).
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/t7Oxw5b_OpDL6yQVWN70ZjxO6hTCaZeW

# Flashbots Sepolia relay (default; override to point at a local Anvil node in tests).
# FLASHBOTS_RPC=https://relay-sepolia.flashbots.net
